                            // Filter conversations based on mode
                            let filtered = conversations;
                            if (mode !== 'unified') {
                                filtered = conversations.filter(c => c.platform === mode);
            }

                            document.getElementById('empty-state').classList.add('hidden');
                            renderConversations(filtered);

                            // Show empty if no convos
                            if (filtered.length === 0) {
                                document.getElementById('messages-area').innerHTML = `<div class="flex-1 flex items-center justify-center text-2xl text-slate-400">No ${mode} messages yet</div>`;
