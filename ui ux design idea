                                filtered = filtered.filter(c =>
                                    c.name.toLowerCase().includes(term) ||
                                    (c.lastMessage && c.lastMessage.toLowerCase().includes(term)) ||
                                    (c.subject && c.subject.toLowerCase().includes(term))
                                );
            }

                            renderConversations(filtered);
        }

