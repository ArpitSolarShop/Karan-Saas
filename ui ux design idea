import React, { useState, useEffect, useRef } from 'react';
import {
    Search, MoreVertical, MessageCircle, MessageSquare, Mail,
    Inbox, Archive, Phone, Video, Paperclip, Smile, Mic,
    Send, ArrowLeft, Check, CheckCheck, Image as ImageIcon,
    Settings, Info, X, Play, ChevronDown, Star, Trash2,
    CornerUpLeft, CornerUpRight, Clock, User
} from 'lucide-react';

// --- GLOBAL STYLES ---
const GlobalStyles = () => (
    <style dangerouslySetInnerHTML={{
        __html: `
    .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(161, 161, 170, 0.4); border-radius: 20px; }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(82, 82, 91, 0.4); }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background-color: rgba(161, 161, 170, 0.7); }
    
    @keyframes slideInUp {
      from { transform: translateY(10px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    .msg-animate { animation: slideInUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    
    .fade-in { animation: fadeIn 0.2s ease-in-out forwards; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  `}} />
);

// --- MOCK DATA (UNIFIED INBOX) ---
const currentUser = { name: "You", avatar: "https://i.pravatar.cc/150?u=me", email: "you@omnired.com" };

const mockThreads = [
    { id: 1, channel: 'whatsapp', name: "Emma Watson", avatar: "https://i.pravatar.cc/150?u=1", lastMessage: "Let's catch up later!", time: "10:42 AM", unread: 3, online: true, phone: "+1 234 567 8900" },
    { id: 2, channel: 'email', name: "Design Team", avatar: "https://i.pravatar.cc/150?u=2", subject: "Q3 Roadmap & Figma Updates", lastMessage: "Please review the attached links before our sync.", time: "09:15 AM", unread: 1, email: "design@company.com" },
    { id: 3, channel: 'sms', name: "Amazon Delivery", avatar: "https://ui-avatars.com/api/?name=Amazon&background=e11d48&color=fff", lastMessage: "Your package has been delivered to the front porch.", time: "Yesterday", unread: 0, phone: "262-966" },
    { id: 4, channel: 'whatsapp', name: "Liam Smith", avatar: "https://i.pravatar.cc/150?u=3", lastMessage: "Check out this shot", time: "Yesterday", unread: 0, online: false },
    { id: 5, channel: 'email', name: "Dribbble Digest", avatar: "https://ui-avatars.com/api/?name=Dribbble&background=ea4c89&color=fff", subject: "Top shots of the week", lastMessage: "See what's trending in the design community today.", time: "Tuesday", unread: 0, email: "digest@dribbble.com" },
];

const mockMessages = {
    1: [ // WhatsApp
        { id: 1, type: "text", text: "Hey Emma, how have you been?", sender: "me", time: "10:30 AM", status: "read" },
        { id: 2, type: "text", text: "I've been good! Just wrapped up a big project. 🚀", sender: "them", time: "10:35 AM" },
        { id: 3, type: "text", text: "Definitely! Let's catch up later!", sender: "them", time: "10:42 AM" },
    ],
    2: [ // Email
        { id: 1, type: "email", subject: "Q3 Roadmap & Figma Updates", text: "Hi Team,\n\nI've updated the master Figma file with the new Q3 roadmap components. Please take a look at the 'Unified Inbox' page specifically.\n\nBest,\nJohn", sender: "them", time: "09:15 AM", date: "Today, Sep 24" }
    ],
    3: [ // SMS
        { id: 1, type: "text", text: "Amazon: Your package is 10 stops away.", sender: "them", time: "Yesterday, 2:00 PM" },
        { id: 2, type: "text", text: "Your package has been delivered to the front porch.", sender: "them", time: "Yesterday, 4:30 PM" }
    ]
};

// --- COMPONENTS ---
const IconButton = ({ icon: Icon, onClick, className = "", active = false, title }) => (
    <button
        title={title}
        onClick={onClick}
        className={`group relative inline-flex items-center justify-center rounded-xl p-2.5 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 
      ${active
                ? 'bg-rose-100 text-rose-700 dark:bg-rose-900/40 dark:text-rose-400'
                : 'text-zinc-500 hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50'
            } ${className}`}
    >
        <Icon className="h-5 w-5" strokeWidth={2} />
    </button>
);

const Avatar = ({ src, alt, online, size = "md", className = "" }) => {
    const sizes = { sm: "h-8 w-8", md: "h-10 w-10", lg: "h-12 w-12" };
    return (
        <div className={`relative shrink-0 ${sizes[size]} ${className}`}>
            <img src={src} alt={alt} className="h-full w-full rounded-full object-cover ring-1 ring-zinc-200 dark:ring-zinc-800" />
            {online && <span className="absolute bottom-0 right-0 block h-3 w-3 rounded-full ring-2 ring-white dark:ring-zinc-950 bg-green-500" />}
        </div>
    );
};

// Helper to render the correct channel icon
const ChannelIcon = ({ channel, className = "" }) => {
    if (channel === 'email') return <Mail className={`h-3.5 w-3.5 ${className}`} />;
    if (channel === 'whatsapp') return <MessageCircle className={`h-3.5 w-3.5 ${className}`} />;
    if (channel === 'sms') return <MessageSquare className={`h-3.5 w-3.5 ${className}`} />;
    return null;
};

// --- MAIN APP ---
export default function OmniRedHub() {
    const [activeTab, setActiveTab] = useState('all'); // all, email, whatsapp, sms
    const [activeThreadId, setActiveThreadId] = useState(null);
    const [searchQuery, setSearchQuery] = useState('');
    const [messages, setMessages] = useState(mockMessages);
    const [inputText, setInputText] = useState('');
    const [isMobileView, setIsMobileView] = useState(false);

    const messagesEndRef = useRef(null);
    const activeThread = mockThreads.find(t => t.id === activeThreadId);
    const currentMessages = activeThreadId ? (messages[activeThreadId] || []) : [];

    useEffect(() => {
        messagesEndRef.current?.scrollIntoView({ behavior: "smooth" });
    }, [currentMessages]);

    useEffect(() => {
        const handleResize = () => setIsMobileView(window.innerWidth < 768);
        handleResize();
        window.addEventListener('resize', handleResize);
        return () => window.removeEventListener('resize', handleResize);
    }, []);

    const handleSend = (e) => {
        e.preventDefault();
        if (!inputText.trim() || !activeThreadId) return;

        const newMsg = {
            id: Date.now(),
            type: activeThread.channel === 'email' ? 'email' : 'text',
            text: inputText,
            sender: "me",
            time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
            status: "sent",
            subject: activeThread.channel === 'email' ? `Re: ${activeThread.subject}` : undefined
        };

        setMessages(prev => ({ ...prev, [activeThreadId]: [...(prev[activeThreadId] || []), newMsg] }));
        setInputText('');
    };

    const filteredThreads = mockThreads.filter(t => {
        const matchesTab = activeTab === 'all' || t.channel === activeTab;
        const matchesSearch = t.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
            (t.subject && t.subject.toLowerCase().includes(searchQuery.toLowerCase()));
        return matchesTab && matchesSearch;
    });

    // Layout Booleans
    const showList = !isMobileView || !activeThreadId;
    const showDetail = activeThreadId && !isMobileView || activeThreadId && isMobileView;

    return (
        <div className="flex h-screen w-full overflow-hidden bg-zinc-100 font-sans text-zinc-950 dark:bg-zinc-950 dark:text-zinc-50">
            <GlobalStyles />

            {/* --- 1. APP RAIL (Leftmost Navigation) --- */}
            {!isMobileView && (
                <div className="flex w-[72px] shrink-0 flex-col items-center border-r border-zinc-200 bg-zinc-50 py-4 dark:border-zinc-800 dark:bg-zinc-950 z-20">
                    <Avatar src={currentUser.avatar} size="md" className="mb-6 shadow-sm cursor-pointer hover:opacity-80" />
                    <div className="flex flex-1 flex-col gap-3">
                        <IconButton icon={Inbox} title="Unified Inbox" active={activeTab === 'all'} onClick={() => setActiveTab('all')} />
                        <div className="w-8 h-px bg-zinc-200 dark:bg-zinc-800 mx-auto my-1" />
                        <IconButton icon={Mail} title="Emails" active={activeTab === 'email'} onClick={() => setActiveTab('email')} className="text-blue-500 hover:text-blue-600 dark:text-blue-400" />
                        <IconButton icon={MessageCircle} title="RedApp (WhatsApp)" active={activeTab === 'whatsapp'} onClick={() => setActiveTab('whatsapp')} className="text-green-600 hover:text-green-700 dark:text-green-500" />
                        <IconButton icon={MessageSquare} title="SMS" active={activeTab === 'sms'} onClick={() => setActiveTab('sms')} className="text-purple-500 hover:text-purple-600 dark:text-purple-400" />
                    </div>
                    <div className="flex flex-col gap-3 mt-auto">
                        <IconButton icon={Archive} title="Archive" />
                        <IconButton icon={Settings} title="Settings" />
                    </div>
                </div>
            )}

            {/* --- 2. THREAD LIST PANE --- */}
            {showList && (
                <div className={`flex flex-col border-r border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900 z-10 ${isMobileView ? 'w-full' : 'w-[360px] shrink-0'}`}>
                    {/* List Header */}
                    <div className="flex h-[70px] shrink-0 items-center justify-between px-5 border-b border-zinc-200 dark:border-zinc-800">
                        <h1 className="text-xl font-semibold tracking-tight capitalize">
                            {activeTab === 'all' ? 'Inbox' : activeTab === 'whatsapp' ? 'RedApp' : activeTab}
                        </h1>
                        <IconButton icon={Search} className="md:hidden" />
                    </div>

                    {/* Search Bar */}
                    <div className="p-3 border-b border-zinc-200 dark:border-zinc-800/50">
                        <div className="relative group">
                            <Search className="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-400" />
                            <input
                                placeholder="Search messages..."
                                className="w-full h-9 rounded-lg bg-zinc-100 dark:bg-zinc-800/50 pl-9 pr-4 text-sm outline-none border border-transparent focus:border-rose-500 focus:bg-white dark:focus:bg-zinc-900 transition-all"
                                value={searchQuery}
                                onChange={(e) => setSearchQuery(e.target.value)}
                            />
                        </div>
                    </div>

                    {/* The List */}
                    <div className="flex-1 overflow-y-auto custom-scrollbar">
                        {filteredThreads.map((thread) => (
                            <div
                                key={thread.id}
                                onClick={() => setActiveThreadId(thread.id)}
                                className={`group cursor-pointer border-b border-zinc-100 dark:border-zinc-800/50 p-3.5 transition-colors hover:bg-zinc-50 dark:hover:bg-zinc-800/60 relative ${activeThreadId === thread.id ? 'bg-rose-50/50 dark:bg-rose-900/10' : ''}`}
                            >
                                <div className="flex gap-3">
                                    <div className="relative">
                                        <Avatar src={thread.avatar} alt={thread.name} online={thread.online} size="lg" />
                                        <div className={`absolute -bottom-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full border-2 border-white dark:border-zinc-900 shadow-sm
                      ${thread.channel === 'email' ? 'bg-blue-500 text-white' : thread.channel === 'whatsapp' ? 'bg-green-500 text-white' : 'bg-purple-500 text-white'}`}>
                                            <ChannelIcon channel={thread.channel} className="h-2.5 w-2.5" />
                                        </div>
                                    </div>

                                    <div className="flex-1 overflow-hidden">
                                        <div className="flex items-center justify-between mb-0.5">
                                            <h3 className={`truncate text-[15px] ${activeThreadId === thread.id || thread.unread > 0 ? 'font-semibold text-zinc-900 dark:text-zinc-100' : 'font-medium text-zinc-800 dark:text-zinc-200'}`}>
                                                {thread.name}
                                            </h3>
                                            <span className={`text-[11px] shrink-0 ${thread.unread > 0 ? 'text-rose-600 dark:text-rose-400 font-semibold' : 'text-zinc-500'}`}>
                                                {thread.time}
                                            </span>
                                        </div>

                                        {thread.channel === 'email' && (
                                            <p className="truncate text-[13px] font-medium text-zinc-700 dark:text-zinc-300 mb-0.5">
                                                {thread.subject}
                                            </p>
                                        )}

                                        <div className="flex items-center justify-between gap-2">
                                            <p className={`truncate text-[13px] ${thread.unread > 0 ? 'text-zinc-700 dark:text-zinc-300 font-medium' : 'text-zinc-500 dark:text-zinc-400'}`}>
                                                {thread.lastMessage}
                                            </p>
                                            {thread.unread > 0 && (
                                                <span className="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-rose-500 text-[10px] font-bold text-white">
                                                    {thread.unread}
                                                </span>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            {/* --- 3. DETAIL PANE (Dynamic based on channel) --- */}
            {showDetail ? (
                <div className="flex flex-1 flex-col relative bg-[#f8fafc] dark:bg-[#0f1115] z-0">

                    {/* Dynamic Header */}
                    <header className="flex h-[70px] shrink-0 items-center justify-between border-b border-zinc-200 bg-white/90 backdrop-blur-md px-4 dark:border-zinc-800 dark:bg-zinc-900/90 shadow-sm z-10">
                        <div className="flex items-center gap-3">
                            {isMobileView && (
                                <IconButton icon={ArrowLeft} onClick={() => setActiveThreadId(null)} className="-ml-2 mr-1" />
                            )}
                            <Avatar src={activeThread.avatar} alt={activeThread.name} size="md" />
                            <div className="flex flex-col">
                                <div className="flex items-center gap-2">
                                    <h2 className="text-[16px] font-semibold text-zinc-900 dark:text-zinc-100">{activeThread.name}</h2>
                                    <span className={`px-1.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider
                    ${activeThread.channel === 'email' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' :
                                            activeThread.channel === 'whatsapp' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' :
                                                'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400'}`}>
                                        {activeThread.channel}
                                    </span>
                                </div>
                                <span className="text-[12px] text-zinc-500 dark:text-zinc-400">
                                    {activeThread.channel === 'email' ? activeThread.email : activeThread.phone || 'Online'}
                                </span>
                            </div>
                        </div>
                        <div className="flex items-center gap-1">
                            {activeThread.channel !== 'email' && <IconButton icon={Phone} />}
                            {activeThread.channel !== 'email' && <IconButton icon={Video} />}
                            {activeThread.channel === 'email' && <IconButton icon={Archive} title="Archive" />}
                            <IconButton icon={MoreVertical} />
                        </div>
                    </header>

                    {/* Dynamic Content Area */}
                    <div className="relative flex-1 overflow-y-auto custom-scrollbar flex flex-col p-4 sm:p-6">

                        {/* Background for Chats only */}
                        {activeThread.channel !== 'email' && (
                            <div
                                className="absolute inset-0 opacity-[0.03] dark:opacity-[0.02] pointer-events-none z-0"
                                style={{ backgroundImage: `url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23e11d48' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")` }}
                            />
                        )}

                        <div className="flex-1 relative z-10 flex flex-col justify-end">

                            {/* --- EMAIL VIEW --- */}
                            {activeThread.channel === 'email' && (
                                <div className="flex-1 flex flex-col gap-4 mt-4 h-full justify-start">
                                    <h1 className="text-2xl font-bold text-zinc-900 dark:text-zinc-100 px-2">{activeThread.subject}</h1>

                                    {currentMessages.map((msg) => (
                                        <div key={msg.id} className="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl p-6 shadow-sm msg-animate">
                                            <div className="flex justify-between items-start mb-6">
                                                <div className="flex gap-3">
                                                    <Avatar src={msg.sender === 'me' ? currentUser.avatar : activeThread.avatar} size="md" />
                                                    <div>
                                                        <p className="font-semibold text-[15px] text-zinc-900 dark:text-zinc-100">
                                                            {msg.sender === 'me' ? currentUser.name : activeThread.name}
                                                        </p>
                                                        <p className="text-[12px] text-zinc-500">to {msg.sender === 'me' ? activeThread.email : 'me'}</p>
                                                    </div>
                                                </div>
                                                <div className="flex items-center gap-4 text-zinc-500 text-[12px]">
                                                    <span>{msg.date || msg.time}</span>
                                                    <div className="flex gap-1">
                                                        <IconButton icon={CornerUpLeft} className="h-8 w-8 p-1.5" title="Reply" />
                                                        <IconButton icon={MoreVertical} className="h-8 w-8 p-1.5" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div className="text-[15px] text-zinc-800 dark:text-zinc-300 whitespace-pre-wrap leading-relaxed">
                                                {msg.text}
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            )}

                            {/* --- CHAT/SMS VIEW --- */}
                            {activeThread.channel !== 'email' && currentMessages.map((msg, index) => {
                                const isMe = msg.sender === 'me';
                                const prevMsg = index > 0 ? currentMessages[index - 1] : null;
                                const isFirstInGroup = !prevMsg || prevMsg.sender !== msg.sender;

                                // Bubble colors based on channel
                                const meBubbleColor = activeThread.channel === 'whatsapp' ? 'bg-rose-600 text-white' : 'bg-purple-600 text-white';

                                return (
                                    <div key={msg.id} className={`flex ${isMe ? 'justify-end' : 'justify-start'} ${isFirstInGroup ? 'mt-3' : 'mt-1'} msg-animate`}>
                                        <div
                                            className={`relative max-w-[85%] sm:max-w-[70%] px-3.5 py-2 shadow-sm
                        ${isMe
                                                    ? `${meBubbleColor} rounded-l-2xl rounded-tr-2xl ${isFirstInGroup ? 'rounded-br-sm' : 'rounded-br-2xl'}`
                                                    : `bg-white text-zinc-900 dark:bg-zinc-800 dark:text-zinc-100 rounded-r-2xl rounded-tl-2xl border border-zinc-100 dark:border-zinc-800 ${isFirstInGroup ? 'rounded-bl-sm' : 'rounded-bl-2xl'}`
                                                }`}
                                        >
                                            <p className="text-[15px] leading-relaxed break-words pr-12">{msg.text}</p>

                                            <div className={`absolute bottom-1 right-2 flex items-center gap-1 text-[10px] font-medium ${isMe ? 'text-white/80' : 'text-zinc-500 dark:text-zinc-400'}`}>
                                                <span>{msg.time}</span>
                                                {isMe && activeThread.channel === 'whatsapp' && (
                                                    msg.status === 'read' ? <CheckCheck className="h-3.5 w-3.5 text-blue-300" /> : <Check className="h-3.5 w-3.5" />
                                                )}
                                            </div>
                                        </div>
                                    </div>
                                );
                            })}
                            <div ref={messagesEndRef} className="h-4" />
                        </div>
                    </div>

                    {/* Dynamic Input Area */}
                    <footer className="relative z-10 bg-white/90 backdrop-blur-md px-4 py-3 dark:bg-zinc-900/90 border-t border-zinc-200 dark:border-zinc-800">
                        <form onSubmit={handleSend} className="flex items-end gap-2 max-w-5xl mx-auto">

                            {activeThread.channel !== 'email' && (
                                <div className="flex items-center gap-1 pb-1">
                                    <IconButton icon={Smile} className="text-zinc-500 hover:text-rose-600 dark:hover:text-rose-400" />
                                    <IconButton icon={Paperclip} className="text-zinc-500 hover:text-rose-600 dark:hover:text-rose-400 hidden sm:inline-flex" />
                                </div>
                            )}

                            <div className="flex-1 relative">
                                <textarea
                                    value={inputText}
                                    onChange={(e) => setInputText(e.target.value)}
                                    onKeyDown={(e) => {
                                        if (e.key === 'Enter' && !e.shiftKey) {
                                            e.preventDefault();
                                            handleSend(e);
                                        }
                                    }}
                                    placeholder={activeThread.channel === 'email' ? "Write a reply..." : activeThread.channel === 'whatsapp' ? "Type a message..." : "Text message..."}
                                    className={`w-full resize-none border border-zinc-200 bg-zinc-50 px-4 py-3 text-[15px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100 custom-scrollbar ${activeThread.channel === 'email' ? 'rounded-xl min-h-[100px]' : 'rounded-full pr-12 h-[46px] pt-3.5'}`}
                                    rows={activeThread.channel === 'email' ? "4" : "1"}
                                    style={{ maxHeight: activeThread.channel === 'email' ? '300px' : '120px' }}
                                />
                            </div>

                            <div className={`pb-1 ${activeThread.channel === 'email' ? 'absolute bottom-5 right-6' : ''}`}>
                                <button
                                    type="submit"
                                    disabled={!inputText.trim()}
                                    className={`flex items-center justify-center rounded-full text-white shadow-md transition-transform active:scale-95 disabled:opacity-50 disabled:scale-100
                    ${activeThread.channel === 'email' ? 'bg-blue-600 hover:bg-blue-700 h-9 px-4 rounded-md gap-2 font-medium' :
                                            activeThread.channel === 'whatsapp' ? 'bg-rose-600 hover:bg-rose-700 h-[42px] w-[42px]' :
                                                'bg-purple-600 hover:bg-purple-700 h-[42px] w-[42px]'}`}
                                >
                                    {activeThread.channel === 'email' ? (
                                        <>Send <Send className="h-4 w-4" /></>
                                    ) : (
                                        <Send className="h-5 w-5 ml-0.5" />
                                    )}
                                </button>
                            </div>
                        </form>
                    </footer>
                </div>
            ) : (
                /* Empty State */
                <div className="hidden md:flex flex-1 flex-col items-center justify-center bg-[#f8fafc] dark:bg-[#0f1115] z-0">
                    <div className="mb-6 rounded-full bg-zinc-100 p-8 dark:bg-zinc-900 shadow-inner">
                        <Inbox className="h-16 w-16 text-zinc-400 dark:text-zinc-500" strokeWidth={1} />
                    </div>
                    <h2 className="text-2xl font-semibold text-zinc-800 dark:text-zinc-200">Omni Red Hub</h2>
                    <p className="mt-2 max-w-md text-center text-zinc-500 dark:text-zinc-400 leading-relaxed">
                        Select a thread to view your emails, texts, and RedApp messages all in one place.
                    </p>
                </div>
            )}

            {/* Mobile Bottom Navigation (Visible only on mobile when not in a chat) */}
            {isMobileView && !activeThreadId && (
                <div className="absolute bottom-0 left-0 right-0 h-16 bg-white dark:bg-zinc-900 border-t border-zinc-200 dark:border-zinc-800 flex items-center justify-around px-2 z-50">
                    <IconButton icon={Inbox} active={activeTab === 'all'} onClick={() => setActiveTab('all')} className="flex-col gap-1 w-16 !rounded-lg" />
                    <IconButton icon={Mail} active={activeTab === 'email'} onClick={() => setActiveTab('email')} className="flex-col gap-1 w-16 !rounded-lg text-blue-500" />
                    <IconButton icon={MessageCircle} active={activeTab === 'whatsapp'} onClick={() => setActiveTab('whatsapp')} className="flex-col gap-1 w-16 !rounded-lg text-green-500" />
