generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkflowRule {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  description  String?
  isActive     Boolean   @default(true)
  trigger      String
  condition    Json      @default("[]")
  action       String
  actionParams Json      @default("{}")
  runCount     Int       @default(0)
  lastRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  @@map("workflow_rules")
}

model Tenant {
  id                String             @id @default(uuid())
  name              String
  subdomain         String             @unique
  plan              TenantPlan         @default(STARTER)
  maxAgents         Int                @default(10)
  telephonyProvider String?
  telephonyApiKey   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  settings          Json               @default("{}")
  approvalRequests  ApprovalRequest[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  calls             Call[]
  campaigns         Campaign[]
  deals             Deal[]
  dispositions      Disposition[]
  knowledgeArticles KnowledgeArticle[]
  landingPages      LandingPage[]
  leadLists         LeadList[]
  leads             Lead[]
  marketingJourneys MarketingJourney[]
  notifications     Notification[]
  quotes            Quote[]
  scripts           Script[]
  suppressions      Suppression[]
  teams             Team[]
  tickets           Ticket[]
  users             User[]
  whatsAppInstances WhatsAppInstance[]
  workbooks         Workbook[]
  workflowRules     WorkflowRule[]

  @@map("tenants")
}

model User {
  id                String             @id @default(uuid())
  tenantId          String
  email             String             @unique
  phone             String?
  passwordHash      String
  firstName         String
  lastName          String
  role              Role               @default(AGENT)
  extension         String?
  sipUsername       String?            @unique
  sipPassword       String?
  agentStatus       AgentStatus        @default(OFFLINE)
  teamId            String?
  supervisorId      String?
  isActive          Boolean            @default(true)
  aiCoachingScore   Float?
  mfaEnabled        Boolean            @default(false)
  mfaSecret         String?
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  activities        Activity[]
  dailyStats        AgentDailyStat[]
  locations         AgentLocation[]
  statusLogs        AgentStatusLog[]
  approvalRequests  ApprovalRequest[]  @relation("ApproverRequests")
  attachments       Attachment[]
  auditLogs         AuditLog[]
  callbacks         Callback[]         @relation("CallbackAgent")
  calls             Call[]             @relation("AgentCalls")
  campaignAgents    CampaignAgent[]
  createdCampaigns  Campaign[]         @relation("CampaignCreator")
  deals             Deal[]
  followups         Followup[]
  knowledgeArticles KnowledgeArticle[]
  importedLists     LeadList[]         @relation("ListImporter")
  assignedLeads     Lead[]             @relation("AssignedTo")
  notes             Note[]
  notifications     Notification[]
  quotes            Quote[]
  createdScripts    Script[]           @relation("ScriptAuthor")
  addedSuppressions Suppression[]      @relation("SuppressionAdder")
  tasks             Task[]             @relation("TaskAssignee")
  managedTeams      Team[]             @relation("TeamManager")
  ticketMessages    TicketMessage[]
  ticketsAssigned   Ticket[]
  supervisor        User?              @relation("SupervisorAgent", fields: [supervisorId], references: [id])
  subordinates      User[]             @relation("SupervisorAgent")
  team              Team?              @relation("TeamMembers", fields: [teamId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId, role])
  @@map("users")
}

model Team {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  supervisorId String
  createdAt    DateTime @default(now())
  supervisor   User     @relation("TeamManager", fields: [supervisorId], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  members      User[]   @relation("TeamMembers")

  @@map("teams")
}

model Lead {
  id              String           @id @default(uuid())
  tenantId        String
  firstName       String
  lastName        String?
  name            String?
  phone           String
  phoneSecondary  String?
  email           String?
  company         String?
  source          String?
  status          LeadStatus       @default(NEW)
  score           Int              @default(0)
  priority        Int              @default(1)
  assignedTo      String?
  campaignId      String?
  isDnc           Boolean          @default(false)
  dncRegisteredAt DateTime?
  lastContactedAt DateTime?
  nextFollowupAt  DateTime?
  customFields    Json             @default("{}")
  tags            String[]         @default([])
  city            String?
  state           String?
  country         String           @default("IN")
  consentStatus   String?
  consentExpiry   DateTime?
  aiSentimentLast String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  activities      Activity[]
  attachments     Attachment[]
  callbacks       Callback[]
  calls           Call[]
  deals           Deal[]
  followups       Followup[]
  agent           User?            @relation("AssignedTo", fields: [assignedTo], references: [id])
  campaign        Campaign?        @relation(fields: [campaignId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  notes           Note[]
  pageSubmissions PageSubmission[]
  quotes          Quote[]
  tasks           Task[]
  tickets         Ticket[]

  @@unique([phone, campaignId])
  @@index([tenantId, assignedTo])
  @@index([status, score(sort: Desc)])
  @@index([phone])
  @@index([nextFollowupAt])
  @@map("leads")
}

model Deal {
  id                String       @id @default(uuid())
  tenantId          String
  leadId            String
  ownerId           String
  name              String
  value             Float        @default(0)
  currency          String       @default("INR")
  stage             String       @default("PROSPECTING")
  probability       Int          @default(10)
  expectedCloseDate DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  attachments       Attachment[]
  lead              Lead         @relation(fields: [leadId], references: [id])
  owner             User         @relation(fields: [ownerId], references: [id])
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  quotes            Quote[]

  @@index([leadId])
  @@map("deals")
}

model Quote {
  id          String       @id @default(uuid())
  tenantId    String
  leadId      String
  dealId      String?
  authorId    String
  version     String       @default("v1")
  totalValue  Float        @default(0)
  status      String       @default("DRAFT")
  lineItems   Json         @default("[]")
  validUntil  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  author      User         @relation(fields: [authorId], references: [id])
  deal        Deal?        @relation(fields: [dealId], references: [id])
  lead        Lead         @relation(fields: [leadId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id])

  @@index([leadId])
  @@map("quotes")
}

model Attachment {
  id           String   @id @default(uuid())
  tenantId     String
  leadId       String
  dealId       String?
  quoteId      String?
  uploadedById String
  name         String
  url          String
  fileType     String?
  fileSize     Int?
  createdAt    DateTime @default(now())
  deal         Deal?    @relation(fields: [dealId], references: [id])
  lead         Lead     @relation(fields: [leadId], references: [id])
  quote        Quote?   @relation(fields: [quoteId], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@index([leadId])
  @@map("attachments")
}

model Call {
  id                 String          @id @default(uuid())
  tenantId           String
  leadId             String
  agentId            String
  campaignId         String?
  callDirection      CallDirection   @default(OUTBOUND)
  callType           CallType        @default(MANUAL)
  phoneDialed        String
  telephonyCallSid   String?         @unique
  status             CallStatus
  dispositionId      String?
  startedAt          DateTime?
  endedAt            DateTime?
  durationSeconds    Int             @default(0)
  talkTimeSeconds    Int             @default(0)
  holdTimeSeconds    Int             @default(0)
  recordingUrl       String?
  localRecordingPath String?
  notes              String?
  isAmd              Boolean         @default(false)
  aiSummary          String?
  aiSentiment        String?
  aiKeyObjections    String[]        @default([])
  complianceFlags    String[]        @default([])
  createdAt          DateTime        @default(now())
  transcript         CallTranscript?
  callbacks          Callback[]
  agent              User            @relation("AgentCalls", fields: [agentId], references: [id])
  campaign           Campaign?       @relation(fields: [campaignId], references: [id])
  disposition        Disposition?    @relation(fields: [dispositionId], references: [id])
  lead               Lead            @relation(fields: [leadId], references: [id])
  tenant             Tenant          @relation(fields: [tenantId], references: [id])

  @@index([agentId, createdAt(sort: Desc)])
  @@index([leadId])
  @@index([campaignId, createdAt])
  @@map("calls")
}

model Disposition {
  id         String              @id @default(uuid())
  tenantId   String
  name       String
  code       String
  category   DispositionCategory
  isCallback Boolean             @default(false)
  colorHex   String              @default("#888888")
  isActive   Boolean             @default(true)
  sortOrder  Int                 @default(0)
  calls      Call[]
  tenant     Tenant              @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@map("dispositions")
}

model Callback {
  id          String         @id @default(uuid())
  leadId      String
  agentId     String
  callId      String?
  scheduledAt DateTime
  notes       String?
  status      FollowupStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  agent       User           @relation("CallbackAgent", fields: [agentId], references: [id])
  call        Call?          @relation(fields: [callId], references: [id])
  lead        Lead           @relation(fields: [leadId], references: [id])

  @@index([scheduledAt])
  @@map("callbacks")
}

model Campaign {
  id                 String             @id @default(uuid())
  tenantId           String
  name               String
  description        String?
  type               CampaignType       @default(OUTBOUND)
  dialerMode         CallType           @default(PREVIEW)
  status             CampaignStatus     @default(DRAFT)
  startDate          DateTime
  endDate            DateTime?
  callingStartTime   String             @default("09:00")
  callingEndTime     String             @default("20:00")
  timezone           String             @default("Asia/Kolkata")
  maxAttemptsPerLead Int                @default(5)
  retryIntervalHours Int                @default(4)
  scriptId           String?
  createdById        String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  calls              Call[]
  campaignAgents     CampaignAgent[]
  leadLists          CampaignLeadList[]
  createdBy          User               @relation("CampaignCreator", fields: [createdById], references: [id])
  script             Script?            @relation(fields: [scriptId], references: [id])
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  leads              Lead[]

  @@map("campaigns")
}

model CampaignAgent {
  campaignId  String
  agentId     String
  assignedAt  DateTime @default(now())
  dailyTarget Int?
  agent       User     @relation(fields: [agentId], references: [id])
  campaign    Campaign @relation(fields: [campaignId], references: [id])

  @@id([campaignId, agentId])
  @@map("campaign_agents")
}

model LeadList {
  id                String             @id @default(uuid())
  tenantId          String
  name              String
  totalLeads        Int                @default(0)
  importedBy        String
  sourceFile        String?
  createdAt         DateTime           @default(now())
  campaignLeadLists CampaignLeadList[]
  importer          User               @relation("ListImporter", fields: [importedBy], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id])

  @@map("lead_lists")
}

model CampaignLeadList {
  campaignId String
  leadListId String
  priority   Int      @default(1)
  addedAt    DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  leadList   LeadList @relation(fields: [leadListId], references: [id])

  @@id([campaignId, leadListId])
  @@map("campaign_lead_lists")
}

model AgentDailyStat {
  id                 String    @id @default(uuid())
  agentId            String
  statDate           DateTime  @db.Date
  callsMade          Int       @default(0)
  callsAnswered      Int       @default(0)
  callsConverted     Int       @default(0)
  totalTalkTime      Int       @default(0)
  avgHandleTime      Float     @default(0)
  totalBreakTime     Int       @default(0)
  loginTime          DateTime?
  logoutTime         DateTime?
  callbacksScheduled Int       @default(0)
  callbacksCompleted Int       @default(0)
  agent              User      @relation(fields: [agentId], references: [id])

  @@unique([agentId, statDate])
  @@map("agent_daily_stats")
}

model AgentStatusLog {
  id              String      @id @default(uuid())
  agentId         String
  status          AgentStatus
  reason          String?
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  agent           User        @relation(fields: [agentId], references: [id])

  @@index([agentId, startedAt])
  @@map("agent_status_logs")
}

model Followup {
  id          String         @id @default(uuid())
  leadId      String
  agentId     String
  scheduledAt DateTime
  status      FollowupStatus @default(PENDING)
  notes       String?
  createdAt   DateTime       @default(now())
  agent       User           @relation(fields: [agentId], references: [id])
  lead        Lead           @relation(fields: [leadId], references: [id])

  @@map("followups")
}

model Note {
  id        String   @id @default(uuid())
  leadId    String
  agentId   String
  note      String
  createdAt DateTime @default(now())
  agent     User     @relation(fields: [agentId], references: [id])
  lead      Lead     @relation(fields: [leadId], references: [id])

  @@map("notes")
}

model Activity {
  id           String   @id @default(uuid())
  leadId       String
  userId       String
  activityType String
  description  String
  createdAt    DateTime @default(now())
  lead         Lead     @relation(fields: [leadId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@map("activities")
}

model Tag {
  id   String @id @default(uuid())
  name String @unique

  @@map("tags")
}

model Task {
  id         String   @id @default(uuid())
  leadId     String?
  assignedTo String
  taskType   String?
  title      String
  dueDate    DateTime
  status     String   @default("PENDING")
  notes      String?
  createdAt  DateTime @default(now())
  user       User     @relation("TaskAssignee", fields: [assignedTo], references: [id])
  lead       Lead?    @relation(fields: [leadId], references: [id])

  @@index([dueDate, assignedTo])
  @@map("tasks")
}

model Script {
  id        String     @id @default(uuid())
  tenantId  String
  name      String
  content   String
  version   Int        @default(1)
  createdBy String
  createdAt DateTime   @default(now())
  campaigns Campaign[]
  author    User       @relation("ScriptAuthor", fields: [createdBy], references: [id])
  tenant    Tenant     @relation(fields: [tenantId], references: [id])

  @@map("scripts")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  entityType String
  entityId   String
  action     String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id          String    @id @default(uuid())
  tenantId    String
  recipientId String
  type        String
  title       String
  body        String?
  entityType  String?
  entityId    String?
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  recipient   User      @relation(fields: [recipientId], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@map("notifications")
}

model Suppression {
  id        String    @id @default(uuid())
  tenantId  String
  phoneE164 String
  type      String
  reason    String?
  until     DateTime?
  addedBy   String?
  addedAt   DateTime  @default(now())
  adder     User?     @relation("SuppressionAdder", fields: [addedBy], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phoneE164])
  @@map("suppressions")
}

model Workbook {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sheets    Sheet[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("workbooks")
}

model Sheet {
  id         String        @id @default(uuid())
  workbookId String
  name       String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  columns    SheetColumn[]
  rows       SheetRow[]
  views      SheetView[]
  workbook   Workbook      @relation(fields: [workbookId], references: [id], onDelete: Cascade)

  @@map("sheets")
}

model SheetColumn {
  id        String     @id @default(uuid())
  sheetId   String
  key       String
  name      String
  dataType  ColumnType @default(TEXT)
  position  Int
  width     Int        @default(120)
  formula   String?
  createdAt DateTime   @default(now())
  sheet     Sheet      @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([sheetId, key])
  @@map("sheet_columns")
}

model SheetRow {
  id        String   @id @default(uuid())
  sheetId   String
  rowIndex  Int
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sheet     Sheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([sheetId, rowIndex])
  @@index([sheetId, rowIndex])
  @@map("sheet_rows")
}

model SheetView {
  id            String   @id @default(uuid())
  sheetId       String
  name          String
  filters       Json     @default("[]")
  sorts         Json     @default("[]")
  hiddenColumns Json     @default("[]")
  createdAt     DateTime @default(now())
  sheet         Sheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@map("sheet_views")
}

model AiConfig {
  id        String  @id @default(uuid())
  modelType String
  provider  String
  version   String
  isActive  Boolean @default(true)

  @@map("ai_configs")
}

model CallTranscript {
  id            String   @id @default(uuid())
  callId        String   @unique
  text          String
  sentiment     String?
  keywordsFound String[] @default([])
  talkRatio     Int?
  rawResult     Json?
  createdAt     DateTime @default(now())
  call          Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@map("call_transcripts")
}

model Ticket {
  id          String          @id @default(uuid())
  tenantId    String
  leadId      String?
  assignedTo  String?
  subject     String
  description String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)
  slaDueAt    DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  messages    TicketMessage[]
  agent       User?           @relation(fields: [assignedTo], references: [id])
  lead        Lead?           @relation(fields: [leadId], references: [id])
  tenant      Tenant          @relation(fields: [tenantId], references: [id])

  @@map("tickets")
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  senderId   String?
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User?    @relation(fields: [senderId], references: [id])
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

model KnowledgeArticle {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  slug        String   @unique
  content     String
  category    String
  isPublished Boolean  @default(true)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@map("knowledge_articles")
}

model MarketingJourney {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  trigger   String
  steps     Json     @default("[]")
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("marketing_journeys")
}

model LandingPage {
  id          String           @id @default(uuid())
  tenantId    String
  name        String
  slug        String           @unique
  htmlContent String
  cssContent  String?
  isPublished Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  submissions PageSubmission[]

  @@map("landing_pages")
}

model PageSubmission {
  id            String      @id @default(uuid())
  landingPageId String
  leadId        String?
  formData      Json
  createdAt     DateTime    @default(now())
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  lead          Lead?       @relation(fields: [leadId], references: [id])

  @@map("page_submissions")
}

model ApprovalRequest {
  id          String         @id @default(uuid())
  tenantId    String
  requesterId String
  approverId  String?
  entityType  String
  entityId    String
  status      ApprovalStatus @default(PENDING)
  notes       String?
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?
  requester   User           @relation("ApproverRequests", fields: [requesterId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  @@map("approval_requests")
}

model AgentLocation {
  id        String   @id @default(uuid())
  agentId   String
  latitude  Float
  longitude Float
  accuracy  Float?
  battery   Int?
  timestamp DateTime @default(now())
  agent     User     @relation(fields: [agentId], references: [id])

  @@index([agentId, timestamp])
  @@map("agent_locations")
}

model WhatsAppInstance {
  id                 String              @id @default(cuid())
  tenantId           String
  name               String              @unique
  phoneNumber        String?
  connectionType     WaConnectionType    @default(BAILEYS_NATIVE)
  connectionStatus   WaConnectionStatus  @default(disconnected)
  phoneNumberId      String?
  wabaId             String?
  accessToken        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  businessName       String?
  webhookVerifyToken String?
  authStore          WhatsAppAuthState[]
  contacts           WhatsAppContact[]
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  messages           WhatsAppMessage[]
  templates          WhatsAppTemplate[]

  @@map("whatsapp_instances")
}

model WhatsAppAuthState {
  id         String           @id @default(cuid())
  instanceId String
  type       String           @db.VarChar(100)
  keyId      String           @db.VarChar(255)
  data       String
  instance   WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, type, keyId])
  @@map("whatsapp_auth_states")
}

model WhatsAppMessage {
  id          String             @id @default(cuid())
  instanceId  String
  direction   WaMessageDirection
  remoteJid   String
  messageId   String             @unique
  messageType String
  messageData Json
  status      String             @default("SERVER_ACK")
  timestamp   DateTime           @default(now())
  instance    WhatsAppInstance   @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, remoteJid])
  @@map("whatsapp_messages")
}

model WhatsAppContact {
  id         String           @id @default(cuid())
  instanceId String
  remoteJid  String
  pushName   String?
  profilePic String?
  instance   WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, remoteJid])
  @@map("whatsapp_contacts")
}

model WhatsAppTemplate {
  id         String           @id @default(cuid())
  instanceId String
  templateId String
  name       String
  category   String
  language   String
  status     String           @default("PENDING")
  components Json             @default("[]")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  instance   WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, name, language])
  @@map("whatsapp_templates")
}

