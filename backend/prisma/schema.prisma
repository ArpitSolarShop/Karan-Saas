  entityType    String
  entityId      String
  value         Json   
  @@unique([customFieldId, entityType, entityId])
  @@index([entityType, entityId])
}

model BusinessHours {
  id        String  @id @default(uuid())
  name      String
  timezone  String  @default("Asia/Kolkata")
