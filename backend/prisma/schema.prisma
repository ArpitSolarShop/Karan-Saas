  holidays  Holiday[]
  
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId])
}

model BusinessHourSlot {
  id              String @id @default(uuid())
  businessHoursId String
